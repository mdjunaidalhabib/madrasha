+/**
+ * Builds a compact, machine-readable value for a document's QR code.
+ * Uses the raw record fields (not Bangla-formatted) so the code stays
+ * reliably scannable. Returns "" when there isn't enough data to identify
+ * the record, in which case the QR block simply won't render.
+ */
+export const buildDocumentQrValue = (row: Record<string, any>, docType: string) => {
+  const identifier = row?.registration_no || row?.roll || row?.id;
+  if (!identifier) return "";
+
+  return [docType, identifier, row?.student_name, row?.class_name, row?.academic_year]
+    .filter((part) => part !== null && part !== undefined && part !== "")
+    .join("|");
+};
+
+/**
+ * Builds the QR code value for a printed money receipt.
+ */
+export const buildReceiptQrValue = (receipt: Record<string, any>) => {
+  const identifier = receipt?.receipt_no || `${receipt?.entry_date || ""}-${receipt?.entry_time || ""}`;
+  if (!identifier.replace(/-/g, "")) return "";
+
+  return ["RECEIPT", identifier, receipt?.donor_name, receipt?.amount, receipt?.entry_date]
+    .filter((part) => part !== null && part !== undefined && part !== "")
+    .join("|");
+};
