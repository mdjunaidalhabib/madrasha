diff --git a/frontend/src/components/common/QRCodeBlock.tsx b/frontend/src/components/common/QRCodeBlock.tsx
new file mode 100644
index 0000000..a4b6deb
--- /dev/null
+++ b/frontend/src/components/common/QRCodeBlock.tsx
@@ -0,0 +1,26 @@
+import { QRCodeSVG } from "qrcode.react";
+
+type QRCodeBlockProps = {
+  value: string;
+  size?: number;
+  label?: string;
+  className?: string;
+};
+
+/**
+ * Renders a small QR code for a printable document (ID card, certificate,
+ * admit card, result sheet, receipt...). Renders nothing when there is no
+ * value, so documents remain unaffected until real record data is available.
+ */
+const QRCodeBlock = ({ value, size = 64, label, className = "" }: QRCodeBlockProps) => {
+  if (!value) return null;
+
+  return (
+    <div className={`document-qr-code flex flex-col items-center gap-1 ${className}`}>
+      <QRCodeSVG value={value} size={size} level="M" />
+      {label && <span className="text-[9px] leading-none text-slate-500">{label}</span>}
+    </div>
+  );
+};
+
+export default QRCodeBlock;
