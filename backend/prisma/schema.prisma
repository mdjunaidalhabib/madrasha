// ============================================================
// Prisma Schema — Root Entry Point
// Multi-tenant Madrasa SaaS Platform
//
// This project uses Prisma's multi-file schema (GA since Prisma 6.7,
// currently on 6.19.3 — no preview flag required). All models live
// under `prisma/models/`, grouped by business domain. This file only
// declares the `generator` and `datasource` — do not add models here.
//
// Folder convention (domain -> file):
//   models/system.prisma    -> platform-level catalog: super admin,
//                              plans, module/feature/permission catalog
//   models/tenant.prisma    -> Madrasa (tenant) account, billing,
//                              roles/users, settings, public website
//   models/academic.prisma  -> division/class/book catalog + the
//                              tenant's activation of that catalog
//   models/student.prisma   -> student records
//   models/teacher.prisma   -> teacher records + class/book assignments
//   models/exam.prisma      -> exam definitions
//   models/result.prisma    -> result publishing, summaries, marks
//   models/accounts.prisma  -> income/expense ledger
//
// Reserved for future growth (per the 500+ model target). Add a new
// file under models/ when one of these domains gets its first model —
// Prisma merges every *.prisma file under this directory automatically,
// no other configuration is needed:
//   admission, employee, attendance, fees, payroll, library,
//   hostel, transport, inventory, sms, notice, report
//
// NOTE ON DATABASE ENGINE: migrated from MySQL to PostgreSQL. Raw SQL in
// reports/, accounts/, dashboard/, public-website/, super-admin/ modules
// has been converted: `?` positional placeholders -> `$1, $2, ...`,
// MySQL-only functions (CURDATE, DATE(), DATEDIFF, DATE_ADD, DATE_FORMAT,
// YEAR()) -> Postgres equivalents (CURRENT_DATE, CAST(x AS DATE), date
// subtraction, INTERVAL, TO_CHAR, EXTRACT), and MySQL-only native column
// types (@db.TinyInt, @db.LongText) removed from the model files since
// they don't exist under the postgresql connector.
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
